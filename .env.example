# Semblance Development Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# Google (Gmail + Drive + Calendar)
SEMBLANCE_GOOGLE_CLIENT_ID=
SEMBLANCE_GOOGLE_CLIENT_SECRET=

# GitHub (PKCE — no secret needed)
SEMBLANCE_GITHUB_CLIENT_ID=

# Spotify (PKCE — no secret needed)
SEMBLANCE_SPOTIFY_CLIENT_ID=

# Dropbox
SEMBLANCE_DROPBOX_CLIENT_ID=
SEMBLANCE_DROPBOX_CLIENT_SECRET=

# Notion
SEMBLANCE_NOTION_CLIENT_ID=
SEMBLANCE_NOTION_CLIENT_SECRET=

# Slack
SEMBLANCE_SLACK_CLIENT_ID=
SEMBLANCE_SLACK_CLIENT_SECRET=
