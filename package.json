{
  "name": "semblance-core",
  "version": "1.0.0",
  "private": true,
  "description": "Your Intelligence. Your Device. Your Rules.",
  "repository": {
    "type": "git",
    "url": "https://github.com/skygkruger/semblance-core.git"
  },
  "homepage": "https://semblance.run",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "privacy-audit": "node scripts/privacy-audit/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preflight": "node scripts/preflight.js",
    "preflight:fast": "node scripts/preflight.js --fast",
    "verify": "node scripts/semblance-verify.js",
    "verify:diff": "node scripts/semblance-verify.js --diff",
    "smoke": "node scripts/smoke-test-sidecar.js",
    "install-verify": "node scripts/install-and-verify.js",
    "install-verify:check": "node scripts/install-and-verify.js --no-install",
    "verify:json": "node scripts/semblance-verify.js --json",
    "update-state": "node scripts/update-state.js",
    "update-state:dry": "node scripts/update-state.js --dry-run",
    "data-audit": "node scripts/data-audit.js",
    "data-audit:json": "node scripts/data-audit.js --json",
    "data-audit:strict": "node scripts/data-audit.js --strict"
  },
  "license": "(MIT OR Apache-2.0)",
  "author": "Veridian Synthetics",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "better-sqlite3": "^12.6.2",
    "jsdom": "^28.1.0",
    "nanoid": "^5.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/josefin-sans": "^5.2.8",
    "@fontsource/dm-mono": "^5.2.7",
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1"
  }
}
